# Server
WRAPPER_HOST=127.0.0.1
WRAPPER_PORT=8787

# Upstream provider — any OpenAI-compatible URL + key
UPSTREAM_BASE_URL=https://openrouter.ai/api/v1
UPSTREAM_API_KEY=your-api-key-here
DEFAULT_MODEL=deepseek/deepseek-v4-flash

# Context compression mode
# Options: hybrid | yaml | incremental | raw | minimal | json | table | symbolic | matrix
CONTEXT_MODE=hybrid

# Set to true to auto-select mode per request based on content heuristics
AUTO_MODE=false

# Logging
LOG_REQUESTS=true
LOG_RESPONSES=true
LOG_DIR=logs
